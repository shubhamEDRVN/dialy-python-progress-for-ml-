e_categorical_crossentropy',metrics=['accuracy'])\n","# The fit call for underfit_model will be done later along with other models for consistent history plotting.\n","\n","\n","#Overfitting model:Too Complex,no regularizatn\n","\n","overfit_model=tf.keras.Sequential([\n","    tf.keras.Input(shape=(784,)), # Use Input layer for explicit input shape\n","    tf.keras.layers.Dense(512,activation='relu'),\n","    tf.keras.layers.Dense(512,activation='relu'),\n","    tf.keras.layers.Dense(10,activation='softmax'),\n","])\n","# Compile overfit_model\n","overfit_model.compile(optimizer='adam',loss='sparse_categorical_crossentropy',metrics=['accuracy'])\n","\n","\n","#Good fit model: balanced w dropout\n","good_model=tf.keras.Sequential([\n","    tf.keras.Input(shape=(784,)), # Use Input layer for explicit input shape\n","    tf.keras.layers.Dense(256,activation='relu'),\n","    tf.keras.layers.Dropout(0.3),\n","    tf.keras.layers.Dense(128,activation='relu'),\n","    tf.keras.layers.Dropout(0.3),\n","    tf.keras.layers.Dense(10,activation='softmax'),\n","])\n","# Compile good_model\n","good_model.compile(optimizer='adam',loss='sparse_categorical_crossentropy',metrics=['accuracy'])\n","\n","# Train all models and store their histories\n","history_under=underfit_model.fit(x_train,y_train,epochs=10,validation_data=(x_test,y_test), verbose =0)\n","history_over=overfit_model.fit(x_train,y_train,epochs=10,validation_data=(x_test,y_test), verbose =0)\n","history_good=good_model.fit(x_train,y_train,epochs=10,validation_data=(x_test,y_test), verbose =0)\n","\n","# Optional: Plotting results to compare underfitting, overfitting, and good fit\n","plt.figure(figsize=(12, 6))\n","plt.plot(history_under.history['val_accuracy'], label='Underfit Model Validation Accuracy')\n","plt.plot(history_over.history['val_accuracy'], label='Overfit Model Validation Accuracy')\n","plt.plot(history_good.history['val_accuracy'], label='Good Fit Model Validation Accuracy')\n","plt.title('Validation Accuracy Comparison')\n","plt.xlabel('Epoch')\n","plt.ylabel('Accuracy')\n","plt.legend()\n","plt.show()\n","\n","plt.figure(figsize=(12, 6))\n","plt.plot(history_under.history['val_loss'], label='Underfit Model Validation Loss')\n","plt.plot(history_over.history['val_loss'], label='Overfit Model Validation Loss')\n","plt.plot(history_good.history['val_loss'], label='Good Fit Model Validation Loss')\n","plt.title('Validation Loss Comparison')\n","plt.xlabel('Epoch')\n","plt.ylabel('Loss')\n","plt.legend()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":933},"id":"nZOgZbOIFDuQ","executionInfo":{"status":"ok","timestamp":1780638911831,"user_tz":-330,"elapsed":436822,"user":{"displayName":"Micro Soft","userId":"17653352051831153100"}},"outputId":"7714e3d3-4f81-4009-c00f-435ab906e997"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/keras/src/layers/core/dense.py:106: UserWarning: Do not pass an `input_shape`/`input_dim` argument to a layer. When using Sequential models, prefer using an `Input(shape)` object as the first layer in the model instead.\n","  super().__init__(activity_regularizer=activity_regularizer, **kwargs)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# This script demonstrates a Convolutional Neural Network (CNN) for image classification on the MNIST dataset\n","# and visualizes the filters learned by the first convolutional layer.\n","\n","# Import the TensorFlow library, which is an open-source machine learning platform.\n","import tensorflow as tf\n","# Import Matplotlib for creating static, animated, and interactive visualizations in Python.\n","import matplotlib.pyplot as plt\n","# Import NumPy for numerical operations, especially for handling arrays.\n","import numpy as np\n","# Although Model is imported, it's typically used for the Functional API. For Sequential models, it's not strictly necessary.\n","# from tensorflow.keras.models import Model # This line can be removed if not using Functional API.\n","# Import the MNIST dataset from Keras, a high-level API for building neural networks.\n","from tensorflow.keras.datasets import mnist\n","\n","# 1. Load and preprocess the MNIST dataset\n","# The MNIST dataset consists of 60,000 training examples and 10,000 test examples\n","# of handwritten digits (0-9) in grayscale, each 28x28 pixels.\n","(x_train, y_train), (x_test, y_test) = mnist.load_data()\n","\n","# Reshape the input data to fit the CNN input format: (number_of_samples, height, width, channels).\n","# For grayscale images like MNIST, the number of channels is 1.\n","# `x_train.reshape(-1, 28, 28, 1)` reshapes the training images.\n","# `.astype('float32')` converts pixel values to float for division.\n","# `/ 255.0` normalizes pixel values from the range [0, 255] to [0, 1].\n","# Normalization helps neural networks train faster and more stably.\n","x_train = x_train.reshape(-1, 28, 28, 1).astype('float32') / 255.0\n","x_test = x_test.reshape(-1, 28, 28, 1).astype('float32') / 255.0\n","\n","# 2. Build the CNN model\n","# A Sequential model is a linear stack of layers. This is suitable for simple networks.\n","model = tf.keras.models.Sequential([\n","    # First Convolutional Layer (Conv2D):\n","    # 8: The number of filters (feature detectors) the layer will learn.\n","    # (3, 3): The size of the convolution kernel (filter).\n","    # activation='relu': Rectified Linear Unit activation function, outputs the input directly if positive, else 0.\n","    #   ReLU helps introduce non-linearity and mitigate the vanishing gradient problem.\n","    # input_shape=(28, 28, 1): Specifies the shape of the input data for the first layer.\n","    #   (28 pixels height, 28 pixels width, 1 channel for grayscale).\n","    # name='conv1': Assigns a name to the layer, useful for retrieving its weights later.\n","    tf.keras.layers.Conv2D(8, (3, 3), activation='relu', input_shape=(28, 28, 1), name='conv1'),\n","    # First Max Pooling Layer (MaxPooling2D):\n","    # (2, 2): The size of the pooling window. This layer reduces the spatial dimensions\n","    #   (height and width) of the input by taking the maximum value over the specified window.\n","    #   It helps in reducing computational cost and controlling overfitting.\n","    tf.keras.layers.MaxPooling2D((2, 2)),\n","    # Second Convolutional Layer:\n","    # 16: Number of filters.\n","    # (3, 3): Kernel size.\n","    # activation='relu': ReLU activation.\n","    # name='conv2': Layer name.\n","    tf.keras.layers.Conv2D(16, (3, 3), activation='relu', name='conv2'),\n","    # Second Max Pooling Layer:\n","    # (2, 2): Pooling window size.\n","    tf.keras.layers.MaxPooling2D((2, 2)),\n","\n","    # Flatten Layer:\n","    # Converts the 2D feature maps (output from the last pooling layer) into a 1D vector.\n","    # This is necessary to feed the data into fully connected (Dense) layers.\n","    tf.keras.layers.Flatten(),\n","    # Dense Hidden Layer:\n","    # 64: Number of neurons (units) in this fully connected layer.\n","    # activation='relu': ReLU activation function.\n","    tf.keras.layers.Dense(64, activation='relu'),\n","    # Dense Output Layer:\n","    # 10: Number of neurons, corresponding to the 10 digit classes (0-9).\n","    # activation='softmax': Softmax activation function. It outputs a probability distribution\n","    #   over the 10 classes, where the sum of all probabilities is 1. The class with the highest\n","    #   probability is the model's prediction.\n","    tf.keras.layers.Dense(10, activation='softmax')\n","])\n","\n","# 3. Compile the model\n","# Compiling configures the model for training with a specific optimizer, loss function, and metrics.\n","# optimizer='adam': An adaptive learning rate optimization algorithm. It's generally a good default choice.\n","# loss='sparse_categorical_crossentropy': A loss function suitable for classification problems\n","#   where the labels are integers (not one-hot encoded). It measures the difference between predicted\n","#   probabilities and true labels.\n","# metrics=['accuracy']: The metric to evaluate the model's performance during training and testing.\n","#   Accuracy calculates the proportion of correctly classified samples.\n","model.compile(optimizer='adam', loss='sparse_categorical_crossentropy', metrics=['accuracy'])\n","\n","# 4. Train the model\n","# The model learns from the training data by iteratively adjusting its internal parameters (weights and biases).\n","print(\"\\nStarting model training...\")\n","# model.fit(): Starts the training process.\n","# x_train, y_train: The training data and their corresponding labels.\n","# epochs=5: The number of times the model will iterate over the entire training dataset.\n","#   Each epoch involves processing all training samples and updating the model's weights.\n","model.fit(x_train, y_train, epochs=5)\n","print(\"Model training finished.\\n\")\n","\n","# 5. Visualize the filters from the first convolutional layer ('conv1')\n","# This step allows us to inspect what features the initial layers of the CNN are learning to detect.\n","# model.get_layer('conv1'): Retrieves the convolutional layer named 'conv1'.\n","# .get_weights(): Returns the weights (filters) and biases of the specified layer.\n","#   For a Conv2D layer, weights will have shape (kernel_height, kernel_width, input_channels, output_channels/num_filters)\n","#   and biases will have shape (output_channels/num_filters,).\n","filters, biases = model.get_layer('conv1').get_weights()\n","\n","# Print the shapes to understand the dimensions of the extracted weights.\n","print(f\"Filters shape: {filters.shape}\") # Expected format: (height, width, input_channels, num_filters)\n","print(f\"Biases shape: {biases.shape}\")   # Expected format: (num_filters,)\n","\n","# Plot the 8 filters from the first convolutional layer.\n","# Each filter is a small matrix that slides over the input image to detect patterns.\n","# fig, axes = plt.subplots(2, 4, ...): Creates a figure and a grid of 2 rows and 4 columns of subplots (8 in total).\n","fig, axes = plt.subplots(2, 4, figsize=(12, 6))\n","# Iterate through each of the 8 filters to plot them individually.\n","for i in range(8):\n","    # Extract the i-th filter from the filters array.\n","    # filters[:, :, 0, i]: Selects all rows and columns of the kernel,\n","    #   for the first (and only) input channel (index 0), and the i-th output filter.\n","    f = filters[:, :, 0, i]\n","    # axes.flatten()[i].imshow(f, cmap='gray'): Displays the filter `f` in grayscale\n","    #   on the i-th subplot. `flatten()` converts the 2x4 array of axes into a 1D array.\n","    axes.flatten()[i].imshow(f, cmap='gray')\n","    # axes.flatten()[i].set_title(f'Filter {i+1}'): Sets the title for each subplot.\n","    axes.flatten()[i].set_title(f'Filter {i+1}')\n","    # axes.flatten()[i].axis('off'): Hides the x and y axes ticks for a cleaner visualization of the filter.\n","    axes.flatten()[i].axis('off')\n","# plt.suptitle(): Sets a main title for the entire figure.\n","plt.suptitle('Filters from the First Convolutional Layer', fontsize=16)\n","# plt.tight_layout(): Adjusts subplot params for a tight layout, preventing labels from overlapping.\n","# rect=[0, 0.03, 1, 0.95]: Adjusts the bounding box for the layout, leaving space for the suptitle.\n","plt.tight_layout(rect=[0, 0.03, 1, 0.95])\n","# plt.show(): Displays the generated plot with all the filter visualizations.\n","plt.show()\n","\n","# Optional: Evaluate the model on the test data\n","# This step measures how well the trained model performs on unseen data.\n","# loss, accuracy = model.evaluate(x_test, y_test, verbose=0): Evaluates the model on the test set.\n","#   verbose=0 suppresses output during evaluation.\n","# print(f\"Test Loss: {loss:.4f}\"): Prints the test loss, indicating the model's error rate.\n","# print(f\"Test Accuracy: {accuracy:.4f}\"): Prints the test accuracy, indicating the percentage of correct predictions.\n","# loss, accuracy = model.evaluate(x_test, y_test, verbose=0)\n","# print(f\"Test Loss: {loss:.4f}\")\n","# print(f\"Test Accuracy: {accuracy:.4f}\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":755},"id":"ALsp9fm9ZFqx","executionInfo":{"status":"ok","timestamp":1780889981962,"user_tz":-330,"elapsed":146264,"user":{"displayName":"Shubham Mehta","userId":"04258390246854069980"}},"outputId":"cdcb2488-fb0a-45b4-8548-018e4f659464"},"execution_count":2,"outputs":[{"output_type":"stream","name":"stderr","text":["/usr/local/lib/python3.12/dist-packages/keras/src/layers/convolutional/base_conv.py:113: UserWarning: Do not pass an `input_shape`/`input_dim` argument to a layer. When using Sequential models, prefer using an `Input(shape)` object as the first layer in the model instead.\n","  super().__init__(activity_regularizer=activity_regularizer, **kwargs)\n"]},{"output_type":"stream","name":"stdout","text":["\n","Starting model training...\n","Epoch 1/5\n","\u001b[1m1875/1875\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m27s\u001b[0m 13ms/step - accuracy: 0.9421 - loss: 0.1947\n","Epoch 2/5\n","\u001b[1m1875/1875\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m25s\u001b[0m 13ms/step - accuracy: 0.9800 - loss: 0.0626\n","Epoch 3/5\n","\u001b[1m1875/1875\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m26s\u001b[0m 14ms/step - accuracy: 0.9849 - loss: 0.0469\n","Epoch 4/5\n","\u001b[1m1875/1875\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m25s\u001b[0m 14ms/step - accuracy: 0.9876 - loss: 0.0376\n","Epoch 5/5\n","\u001b[1m1875/1875\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m41s\u001b[0m 14ms/step - accuracy: 0.9903 - loss: 0.0308\n","Model training finished.\n","\n","Filters shape: (3, 3, 8, 16)\n","Biases shape: (16,)\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 8 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["# Import the Model class for creating a functional Keras model.\n","# This is necessary because we are creating a new model (`activation_model`)\n","# by specifying its inputs and outputs, which is characteristic of the Keras Functional API.\n","from tensorflow.keras.models import Model\n","import tensorflow as tf # Ensure tensorflow is imported, although it's likely already in context.\n","\n","# Create a new functional model that outputs activations from intermediate convolutional layers.\n","# This technique is incredibly useful for visualizing the features learned by different layers in the network,\n","# providing valuable insights into what patterns the CNN has learned at various stages of processing.\n","\n","# 1. Identify intermediate convolutional layer outputs.\n","# We iterate through all the layers within our pre-defined 'model' (which was trained in a previous cell).\n","# For each layer, we check if its name contains the substring 'conv' (e.g., 'conv1', 'conv2').\n","# If it's a convolutional layer, we capture its symbolic output tensor using 'layer.output'.\n","# These output tensors represent the feature maps generated by each convolutional layer.\n","layers_outputs = [layer.output for layer in model.layers if 'conv' in layer.name]\n","\n","# 2. Construct a Keras Functional Model specifically for activation extraction.\n","# This new 'activation_model' will mimic the input of our original 'model'.\n","# The `inputs` argument specifies the input tensor(s) that the `activation_model` will expect.\n","# For a `tf.keras.Sequential` model that has already been built (e.g., after calling `.fit()` or `.build()`),\n","# `model.inputs` (note the plural 's') provides the correct list of symbolic input tensors to use.\n","# This is a more robust way to reference the input of a built Sequential model when creating a functional model\n","# compared to `model.input` which can sometimes lead to an AttributeError in certain contexts.\n","# The `outputs` argument is a list of the symbolic output tensors from the intermediate layers\n","# that we collected in the `layers_outputs` list.\n","activation_model = Model(inputs=model.inputs, outputs=layers_outputs)\n","#pick one imafge to visualize\n","img = x_test[0].reshape(1,28,28,1)\n","activations = activation_model.predict(img)\n","first_layer_activation = activations[0] #shape:(1,26,26,8)\n","fig, azes = plt.subplots(1,8, figsize=(15,4))\n","for i in range(8):\n","  axes[i].imshow(first_layer_activation[0,:,:,i],cmap='viridis')\n",""],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"k4QT619-UMAO","executionInfo":{"status":"ok","timestamp":1780890869930,"user_tz":-330,"elapsed":180,"user":{"displayName":"Shubham Mehta","userId":"04258390246854069980"}},"outputId":"17e5403f-33fb-4ef0-ea60-61e4de602731"},"execution_count":5,"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[1m1/1\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m0s\u001b[0m 107ms/step\n"]}]},{"cell_type":"code","source":[],"metadata":{"id":"HCMeG_GNT8Tq"},"execution_count":null,"outputs":[]}],"metadata":{"colab":{"provenance":[]},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}